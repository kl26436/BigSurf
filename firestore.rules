rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin UID — Kevin (sole writer of global catalogs)
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'YpB4kgun28TD3eSBAR8QYfkK4a13';
    }

    // Per-user data: workouts, templates, exercises, equipment, locations (incl. locations.equipment[]), preferences
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Global default exercises (read-only for authenticated users)
    match /exercises/{docId} {
      allow read: if request.auth != null;
    }

    // Global default workout templates (read-only for authenticated users)
    match /workouts/{docId} {
      allow read: if request.auth != null;
    }

    // Global equipment catalog — brand-keyed docs containing lines + machines.
    // All authenticated users read; only admin writes.
    match /equipmentCatalog/{brandId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Error logs: authenticated users can create (capped size so a bad
    // client can't dump megabytes per doc); only admin reads/deletes.
    match /errorLogs/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.keys().size() < 20;
      allow read, delete: if isAdmin();
    }
  }
}
