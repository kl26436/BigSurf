rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user data: workouts, templates, exercises, equipment, locations, preferences
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Global default exercises (read-only for authenticated users)
    match /exercises/{docId} {
      allow read: if request.auth != null;
    }

    // Global default workout templates (read-only for authenticated users)
    match /workouts/{docId} {
      allow read: if request.auth != null;
    }

    // Error logs: any authenticated user can create; read/delete for debugging
    match /errorLogs/{docId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null;
    }
  }
}
