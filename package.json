{
  "name": "bigsurf",
  "version": "1.0.0",
  "description": "A mobile-first workout tracking web application with Firebase backend. Track your gym sessions, manage exercises and equipment, monitor progress with an intuitive interface designed for use at the gym.",
  "main": "service-worker.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint js/",
    "lint:fix": "eslint js/ --fix",
    "format": "prettier --write \"js/**/*.js\" \"*.css\" \"*.html\"",
    "format:check": "prettier --check \"js/**/*.js\" \"*.css\" \"*.html\"",
    "audit:design": "node scripts/design-audit.js",
    "audit:design:strict": "node scripts/design-audit.js --strict"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kl26436/BigSurf.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/kl26436/BigSurf/issues"
  },
  "homepage": "https://github.com/kl26436/BigSurf#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "prettier": "^3.8.2",
    "vitest": "^4.1.4"
  }
}
